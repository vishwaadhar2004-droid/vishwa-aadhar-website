rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'vishwaadhar2004@gmail.com' ||
        request.auth.token.email.lower() == 'vishwaaadhar2004@gmail.com' ||
        request.auth.token.email.lower() == 'vishwa.admin@gmail.com' ||
        request.auth.token.email.lower() == 'admin@vishwaaadhar.com'
      );
    }

    // Allow ANY signed-in user to edit the main content collections for now
    // This ensures that even if there's a weird token issue, they can still work if they are logged in.
    match /gallery_media/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /team_members/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /gallery_page/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /products/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /videos/{docId} { allow read: if true; allow write: if isSignedIn(); }
    
    match /about_page/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /home_content/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /site_settings/{docId} { allow read: if true; allow write: if isSignedIn(); }
    match /products_page/{docId} { allow read: if true; allow write: if isSignedIn(); }

    // Wildcard fallback
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isSignedIn();
    }
  }
}
